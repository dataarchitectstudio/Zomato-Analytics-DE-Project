{
  "name": "Zomato Analytics — Medallion Pipeline",
  "description": "End-to-end data pipeline: Bronze → Silver → Gold → Dashboard",
  "tags": {
    "project": "zomato-analytics",
    "team": "data-engineering",
    "env": "${PIPELINE_ENV}"
  },
  "tasks": [
    {
      "task_key": "bronze_ingestion",
      "description": "Ingest raw data into Bronze layer",
      "notebook_task": {
        "notebook_path": "/Workspace/Zomato-Analytics/bronze/01_bronze_ingestion",
        "base_parameters": {
          "env": "${PIPELINE_ENV}",
          "source_path": "/mnt/zomato-raw/landing",
          "bronze_db": "zomato_bronze",
          "load_type": "incremental"
        }
      },
      "existing_cluster_id": "${CLUSTER_ID}",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "silver_transformation",
      "description": "Cleanse and transform data into Silver layer",
      "depends_on": [
        { "task_key": "bronze_ingestion" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Zomato-Analytics/silver/02_silver_transformation",
        "base_parameters": {
          "env": "${PIPELINE_ENV}",
          "bronze_db": "zomato_bronze",
          "silver_db": "zomato_silver"
        }
      },
      "existing_cluster_id": "${CLUSTER_ID}",
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "gold_aggregation",
      "description": "Build business aggregations in Gold layer",
      "depends_on": [
        { "task_key": "silver_transformation" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Zomato-Analytics/gold/03_gold_aggregation",
        "base_parameters": {
          "env": "${PIPELINE_ENV}",
          "silver_db": "zomato_silver",
          "gold_db": "zomato_gold"
        }
      },
      "existing_cluster_id": "${CLUSTER_ID}",
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "dashboard_refresh",
      "description": "Refresh analytics dashboard",
      "depends_on": [
        { "task_key": "gold_aggregation" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Zomato-Analytics/dashboard/04_analytics_dashboard",
        "base_parameters": {
          "gold_db": "zomato_gold"
        }
      },
      "existing_cluster_id": "${CLUSTER_ID}",
      "timeout_seconds": 1800,
      "max_retries": 1
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 2 * * ?",
    "timezone_id": "Asia/Kolkata",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": ["data-engineering@zomato.com"],
    "on_success": [],
    "no_alert_for_skipped_runs": true
  },
  "max_concurrent_runs": 1
}
